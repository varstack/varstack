{
  "name": "@varstack/types",
  "version": "0.0.0",
  "description": "Type definitions to be used across varstack packages",
  "repository": "https://github.com/varstack/varstack",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown src/**/*.ts --exports --dts --no-fixed-extension --minify",
    "dev": "tsdown src/**/*.ts --exports --dts --no-fixed-extension --watch",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  }
}
