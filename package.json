{
  "name": "varstack",
  "version": "0.0.0",
  "description": "A tool to manage versioning, changelogs, & more",
  "license": "MIT",
  "repository": "https://github.com/varstack/varstack",
  "author": "Avirup Ghosh (github.com/oviirup)",
  "type": "module",
  "bin": "./dist/bin.js",
  "exports": {
    ".": "./dist/bin.js",
    "./package.json": "./package.json",
    "./schema.json": "./schema.json"
  },
  "scripts": {
    "build": "bunx --bun tsdown --minify",
    "dev": "bunx --bun tsdown --watch",
    "format": "biome format --write",
    "lint": "biome check",
    "prepare": "lefthook install",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "enquirer": "^2.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/bun": "^1.3.12",
    "lefthook": "^2.1.5",
    "tsdown": "^0.21.8",
    "typescript": "^6.0.2"
  }
}
