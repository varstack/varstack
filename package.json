{
  "name": "@varstack/root",
  "private": true,
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean",
    "clean:repo": "npx rimraf node_modules .turbo",
    "dev": "turbo run dev",
    "format": "prettier . -wu --cache",
    "format:check": "prettier . -cu",
    "lint": "turbo run lint",
    "lint:repo": "sherif",
    "prepare": "husky",
    "types:check": "turbo run typecheck"
  },
  "devDependencies": {
    "@types/node": "~22.13.10",
    "husky": "~9.1.7",
    "lint-staged": "~15.5.1",
    "prettier": "~3.5.3",
    "prettier-plugin-imports": "~4.2.12",
    "prettier-plugin-pkg": "~0.18.1",
    "prettier-plugin-tailwindcss": "~0.6.11",
    "turbo": "~2.4.4",
    "typescript": "~5.8.2",
    "vitest": "~3.0.9"
  },
  "lint-staged": {
    "*": "prettier -wu --cache"
  }
}
