{
  "name": "monorepo-root",
  "version": "1.3.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "format": "biome format --write",
    "lint": "biome check",
    "prepare": "lefthook install",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/bun": "^1.3.13",
    "lefthook": "^2.1.6",
    "tsdown": "^0.21.10",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.13"
}
