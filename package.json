{
  "name": "varstack",
  "version": "0.0.0",
  "description": "A tool to manage versioning, changelogs, & more",
  "license": "MIT",
  "repository": "https://github.com/varstack/varstack",
  "author": "Avirup Ghosh (github.com/oviirup)",
  "type": "module",
  "bin": "./dist/bin.js",
  "scripts": {
    "build": "tsdown --minify",
    "dev": "tsdown --watch",
    "format": "biome format --write",
    "lint": "biome check",
    "prepare": "lefthook install",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "enquirer": "^2.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "^1.3.10",
    "lefthook": "^2.1.3",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  }
}
