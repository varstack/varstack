{
  "name": "@varstack/root",
  "private": true,
  "packageManager": "pnpm@10.9.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean",
    "clean:repo": "npx rimraf node_modules .turbo",
    "dev": "turbo run dev",
    "format": "prettier . -wu --cache",
    "format:check": "prettier . -cu",
    "lint": "turbo run lint",
    "lint:repo": "sherif",
    "prepare": "husky",
    "types:check": "turbo run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "~9.26.0",
    "@types/node": "~22.15.18",
    "eslint": "~9.26.0",
    "eslint-config-prettier": "~10.1.5",
    "eslint-plugin-only-warn": "~1.1.0",
    "husky": "~9.1.7",
    "lint-staged": "~16.0.0",
    "prettier": "~3.5.3",
    "prettier-plugin-imports": "~4.3.3",
    "prettier-plugin-jsdoc": "~1.3.2",
    "prettier-plugin-pkg": "~0.19.1",
    "prettier-plugin-tailwindcss": "~0.6.11",
    "tinyglobby": "~0.2.13",
    "tsup": "~8.4.0",
    "tsx": "~4.19.4",
    "turbo": "~2.5.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "~8.32.1",
    "vitest": "~3.1.3"
  },
  "lint-staged": {
    "*.{js,mjs,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,json,md,mdx,yaml,gql,html}": [
      "prettier --write"
    ]
  }
}
